{
  "$schema": "https://json.schemastore.org/prettierrc",

  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",

  "jsxSingleQuote": true,
  "singleAttributePerLine": true,

  "proseWrap": "preserve",
  "embeddedLanguageFormatting": "auto"
}
